#!/usr/bin/env bash
# dotfiles-scan — non-interactive data producer for dotter dotfiles manager.
set -euo pipefail

VERSION="1.0.0"

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
MANIFEST="$DOTFILES_DIR/dotfiles.manifest"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DOTFILES_BIN=""

resolve_dotfiles() {
  if [ -x "$SCRIPT_DIR/dotfiles" ]; then
    DOTFILES_BIN="$SCRIPT_DIR/dotfiles"
  elif command -v dotfiles >/dev/null 2>&1; then
    DOTFILES_BIN="$(command -v dotfiles)"
  else
    echo "error: dotfiles executable not found on PATH or in $SCRIPT_DIR" >&2
    exit 1
  fi
}

manifest_lines() {
  [ -f "$MANIFEST" ] || return 0
  grep -vE '^[[:space:]]*(#|$)' "$MANIFEST" || true
}

manifest_has() {
  local rel="$1" t r
  while IFS='|' read -r t r _; do
    [ "$r" = "$rel" ] && return 0
  done <<EOF
$(manifest_lines)
EOF
  return 1
}

candidate_label() {
  local rel="$1"
  case "$rel" in
    .zshrc)              printf 'zsh shell config' ;;
    .bashrc)             printf 'bash shell config' ;;
    .bash_profile)       printf 'bash profile config' ;;
    .profile)            printf 'shell profile' ;;
    .inputrc)            printf 'readline config' ;;
    .gitconfig)          printf 'git configuration' ;;
    .gitignore_global)   printf 'global gitignore' ;;
    .tmux.conf)          printf 'tmux configuration' ;;
    .vimrc)              printf 'vim configuration' ;;
    .editorconfig)       printf 'editor config' ;;
    .curlrc)             printf 'curl configuration' ;;
    .wgetrc)             printf 'wget configuration' ;;
    .ripgreprc)          printf 'ripgrep configuration' ;;
    .digrc)              printf 'dig configuration' ;;
    .config/nvim)        printf 'Neovim configuration' ;;
    .config/git)         printf 'git config directory' ;;
    .config/gh)          printf 'GitHub CLI config' ;;
    .config/starship.toml) printf 'starship prompt config' ;;
    .config/alacritty)   printf 'Alacritty terminal config' ;;
    .config/kitty)       printf 'Kitty terminal config' ;;
    .config/wezterm)     printf 'WezTerm config' ;;
    .config/zellij)      printf 'Zellij multiplexer config' ;;
    .config/helix)       printf 'Helix editor config' ;;
    .config/fish)        printf 'Fish shell config' ;;
    .config/atuin)       printf 'Atuin shell history config' ;;
    .config/bat)         printf 'bat syntax highlighter config' ;;
    .config/lazygit)     printf 'lazygit config' ;;
    .config/ghostty)     printf 'Ghostty terminal config' ;;
    .ssh/config)         printf 'SSH client config' ;;
    .aws/config)         printf 'AWS CLI config' ;;
    .hushlogin)          printf 'hushlogin file' ;;
    *)                   printf '%s configuration' "$rel" ;;
  esac
}

extract_flags() {
  local porcelain="$1"
  if [ -z "$porcelain" ]; then
    printf '-'
    return 0
  fi
  local flags
  flags="$(printf '%s\n' "$porcelain" | awk -F'|' '{print $2}' | sort -u | tr '\n' ',' | sed 's/,$//')"
  if [ -n "$flags" ]; then
    printf '%s' "$flags"
  else
    printf '-'
  fi
}

has_unsafe_flag() {
  local porcelain="$1"
  case "$porcelain" in
    *"|secret|"*|*"|nested-git|"*) return 0 ;;
    *) return 1 ;;
  esac
}

to_rel() {
  local p="$1"
  case "$p" in
    "~/"*) p="$HOME/${p#\~/}" ;;
    "~")   p="$HOME" ;;
    /*)    ;;
    *)     p="$PWD/$p" ;;
  esac
  while [ "${p%/}" != "$p" ]; do p="${p%/}"; done
  case "$p" in
    "$HOME"/*) printf '%s' "${p#"$HOME"/}" ; return 0 ;;
    *) return 1 ;;
  esac
}

cmd_candidates() {
  local cand_list=".zshrc .bashrc .bash_profile .profile .inputrc .gitconfig .gitignore_global .tmux.conf .vimrc .editorconfig .curlrc .wgetrc .ripgreprc .digrc .config/nvim .config/git .config/gh .config/starship.toml .config/alacritty .config/kitty .config/wezterm .config/zellij .config/helix .config/fish .config/atuin .config/bat .config/lazygit .config/ghostty .ssh/config .aws/config .hushlogin"
  local c src kind porcelain flags label

  for c in $cand_list; do
    src="$HOME/$c"
    [ -e "$src" ] || continue
    manifest_has "$c" && continue

    if [ -d "$src" ]; then
      kind="dir"
      [ "$c" != ".ssh" ] || continue
      porcelain="$("$DOTFILES_BIN" audit --porcelain "~/$c" 2>/dev/null || true)"
      if has_unsafe_flag "$porcelain"; then
        continue
      fi
    elif [ -f "$src" ]; then
      kind="file"
      porcelain="$("$DOTFILES_BIN" audit --porcelain "~/$c" 2>/dev/null || true)"
    else
      continue
    fi

    flags="$(extract_flags "$porcelain")"
    label="$(candidate_label "$c")"
    printf '%s|%s|%s|%s\n' "$kind" "$c" "$flags" "$label"
  done
}

file_flags() {
  local f="$1"
  local base="${f##*/}"
  local flags=""

  case "$base" in
    auth*.json|*credential*|*.pem|*.key|.env|*token*|*secret*|id_rsa*)
      flags="${flags:+$flags,}secret"
      ;;
  esac

  if [ -f "$f" ]; then
    local is_large
    is_large="$(find "$f" -size +50M 2>/dev/null || true)"
    if [ -n "$is_large" ]; then
      flags="${flags:+$flags,}large"
    fi
  fi

  if [ -S "$f" ] || [ -p "$f" ]; then
    flags="${flags:+$flags,}socket"
  fi

  case "$base" in
    *.log)
      flags="${flags:+$flags,}log"
      ;;
  esac

  case "$base" in
    *.db|*.sqlite*)
      flags="${flags:+$flags,}db"
      ;;
  esac

  if [ -L "$f" ]; then
    local target
    target="$(readlink "$f" 2>/dev/null || true)"
    case "$target" in
      /*)
        case "$target" in
          "$HOME"/*|"$DOTFILES_DIR"/*) ;;
          *) flags="${flags:+$flags,}foreign-symlink" ;;
        esac
        ;;
    esac
  fi

  if [ -n "$flags" ]; then
    printf '%s' "$flags"
  else
    printf '-'
  fi
}

cmd_expand() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "error: expand requires a target relpath" >&2
    exit 1
  fi

  local target_path
  case "$target" in
    "~/"*|/*) target_path="$target" ;;
    *)        target_path="~/$target" ;;
  esac

  local rel
  if manifest_has "$target"; then
    rel="$target"
  elif ! rel="$(to_rel "$target_path")"; then
    echo "error: $target is outside \$HOME" >&2
    exit 1
  fi

  local src
  if [ -e "$DOTFILES_DIR/$rel" ]; then
    src="$DOTFILES_DIR/$rel"
  else
    src="$HOME/$rel"
  fi

  if [ ! -d "$src" ]; then
    echo "error: $rel is not a directory" >&2
    exit 1
  fi

  local f f_rel size_bytes flags
  find "$src" -type f 2>/dev/null | sort | while IFS= read -r f; do
    f_rel="${f#"$DOTFILES_DIR"/}"
    [ "$f_rel" != "$f" ] || f_rel="${f#"$HOME"/}"
    size_bytes="$(wc -c < "$f" 2>/dev/null | tr -d ' ')"
    flags="$(file_flags "$f")"
    printf 'file|%s|%s|%s\n' "$f_rel" "$flags" "${size_bytes:-0}"
  done
}

cmd_audit() {
  "$DOTFILES_BIN" audit --porcelain "$@"
}

usage() {
  cat <<EOF
dotfiles-scan ${VERSION} — machine-readable scanner for dotter dotfiles manager

USAGE
  dotfiles-scan <command> [options]

COMMANDS
  candidates        List un-tracked candidate config files/dirs in \$HOME
  expand <relpath>  List files inside a tracked directory entry with sizes/flags
  audit [<relpath>] Run porcelain audit against tracked or ad-hoc paths
  help | version

ENVIRONMENT
  DOTFILES_DIR      Repo location (default: \$HOME/.dotfiles)
EOF
}

main() {
  resolve_dotfiles

  [ $# -gt 0 ] || { usage; exit 1; }
  local cmd="$1"; shift
  case "$cmd" in
    candidates)        cmd_candidates "$@" ;;
    expand)            cmd_expand "$@" ;;
    audit)             cmd_audit "$@" ;;
    help|--help|-h)    usage ;;
    version|--version) echo "dotfiles-scan $VERSION" ;;
    *)
      echo "error: unknown scan command: $cmd" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
