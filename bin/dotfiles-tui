#!/usr/bin/env bash
# dotfiles-tui — interactive terminal UI for dotter dotfiles manager built on fzf.
set -euo pipefail

VERSION="1.0.0"

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
MANIFEST="$DOTFILES_DIR/dotfiles.manifest"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Backend Resolution ────────────────────────────────────────────────────────
DOTFILES_BIN=""
SCAN_BIN=""

resolve_backends() {
  if [ -x "$SCRIPT_DIR/dotfiles" ]; then
    DOTFILES_BIN="$SCRIPT_DIR/dotfiles"
  elif command -v dotfiles >/dev/null 2>&1; then
    DOTFILES_BIN="$(command -v dotfiles)"
  else
    echo "error: dotfiles backend executable not found on PATH or in $SCRIPT_DIR" >&2
    exit 1
  fi

  if [ -x "$SCRIPT_DIR/dotfiles-scan" ]; then
    SCAN_BIN="$SCRIPT_DIR/dotfiles-scan"
  elif command -v dotfiles-scan >/dev/null 2>&1; then
    SCAN_BIN="$(command -v dotfiles-scan)"
  else
    SCAN_BIN=""
  fi
}

# ── Dependency & Environment Guards ──────────────────────────────────────────
check_fzf() {
  if ! command -v fzf >/dev/null 2>&1; then
    echo "error: fzf is required for dotfiles-tui but is not installed or not on PATH." >&2
    echo "To install fzf: brew install fzf (or use your system package manager)." >&2
    exit 1
  fi
}

check_tty() {
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    echo "error: dotfiles-tui requires an interactive TTY terminal session." >&2
    exit 1
  fi
}

lower() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

confirm() {
  local prompt="$1" reply
  if [ "${ASSUME_YES:-0}" = "1" ]; then return 0; fi
  if [ ! -r /dev/tty ]; then
    echo "declining (no TTY): $prompt" >&2
    return 1
  fi
  printf "%s [y/N]: " "$prompt" > /dev/tty
  read -r reply < /dev/tty || reply=n
  case "$(lower "${reply:-n}")" in y|yes) return 0 ;; *) return 1 ;; esac
}

# ── Choke-point execution for backend CLI commands ─────────────────────────────
run_cli() {
  if [ "${DOTFILES_TUI_DRY_RUN:-0}" = "1" ]; then
    echo "WOULD-RUN: $*"
  else
    local tool="$1"; shift
    if [ "$tool" = "dotfiles" ]; then
      "$DOTFILES_BIN" "$@"
    elif [ "$tool" = "dotfiles-scan" ]; then
      if [ -n "$SCAN_BIN" ]; then
        "$SCAN_BIN" "$@"
      else
        fallback_scan "$@"
      fi
    else
      "$tool" "$@"
    fi
  fi
}

# ── Fallback scanner logic (when dotfiles-scan is absent) ─────────────────────
fallback_scan() {
  local subcmd="${1:-}"; shift || true
  case "$subcmd" in
    candidates)
      fallback_candidates "$@"
      ;;
    expand)
      fallback_expand "$@"
      ;;
    audit)
      "$DOTFILES_BIN" audit --porcelain "$@"
      ;;
    *)
      echo "unknown scan subcommand: $subcmd" >&2
      return 1
      ;;
  esac
}

manifest_lines() {
  [ -f "$MANIFEST" ] || return 0
  grep -vE '^[[:space:]]*(#|$)' "$MANIFEST" || true
}

manifest_has() {
  local rel="$1" t r
  while IFS='|' read -r t r _; do
    [ "$r" = "$rel" ] && return 0
  done <<EOF
$(manifest_lines)
EOF
  return 1
}

fallback_candidates() {
  local cand_list=".zshrc .bashrc .bash_profile .tmux.conf .gitconfig .vimrc .zshenv .inputrc .config/nvim .config/git .config/fish .config/starship.toml .config/ghostty .config/hypr .config/kitty .config/helix .config/alacritty"
  local c src kind flags audit_out
  for c in $cand_list; do
    src="$HOME/$c"
    [ -e "$src" ] || continue
    manifest_has "$c" && continue
    if [ -d "$src" ]; then kind="dir"; else kind="file"; fi
    audit_out="$("$DOTFILES_BIN" audit --porcelain "$c" 2>/dev/null || true)"
    if [ -n "$audit_out" ]; then
      flags="$(printf '%s\n' "$audit_out" | awk -F'|' '{print $2}' | sort -u | tr '\n' ',' | sed 's/,$//')"
    else
      flags="clean"
    fi
    printf '%s|%s|%s|%s\n' "$kind" "$c" "${flags:-clean}" "$c configuration"
  done
}

fallback_expand() {
  local rel="${1:-}"
  [ -n "$rel" ] || return 1
  local src="$HOME/$rel"
  [ -e "$src" ] || src="$DOTFILES_DIR/$rel"
  [ -d "$src" ] || return 1
  local f f_rel size_bytes audit_out flags
  find "$src" -type f 2>/dev/null | while IFS= read -r f; do
    f_rel="${f#"$HOME"/}"
    [ "$f_rel" != "$f" ] || f_rel="${f#"$DOTFILES_DIR"/}"
    size_bytes="$(wc -c < "$f" 2>/dev/null | tr -d ' ')"
    audit_out="$("$DOTFILES_BIN" audit --porcelain "$f_rel" 2>/dev/null || true)"
    if [ -n "$audit_out" ]; then
      flags="$(printf '%s\n' "$audit_out" | awk -F'|' '{print $2}' | sort -u | tr '\n' ',' | sed 's/,$//')"
    else
      flags="clean"
    fi
    printf 'file|%s|%s|%s\n' "$f_rel" "${flags:-clean}" "${size_bytes:-0}"
  done
}

to_rel() {
  local p="$1"
  case "$p" in
    "~/"*) p="$HOME/${p#\~/}" ;;
    "~")   p="$HOME" ;;
    /*)    ;;
    *)     p="$PWD/$p" ;;
  esac
  while [ "${p%/}" != "$p" ]; do p="${p%/}"; done
  case "$p" in
    "$HOME"/*) printf '%s' "${p#"$HOME"/}" ; return 0 ;;
    *) return 1 ;;
  esac
}

is_linked() {
  local rel="$1"
  local home_path="$HOME/$rel"
  local repo_path="$DOTFILES_DIR/$rel"
  [ -L "$home_path" ] && [ "$(readlink "$home_path")" = "$repo_path" ]
}

# ── Screens ───────────────────────────────────────────────────────────────────

screen_browse() {
  local action="${1:-}" path="${2:-}"
  if [ -n "$action" ]; then
    case "$action" in
      rm|remove)
        [ -n "$path" ] || { echo "error: browse rm requires path" >&2; exit 1; }
        if [ "${DOTFILES_TUI_DRY_RUN:-0}" = "1" ] || confirm "Remove/untrack $path?"; then
          case "$path" in
            "~/"*|/*) run_cli dotfiles rm "$path" ;;
            *)        run_cli dotfiles rm "~/$path" ;;
          esac
        fi
        return 0
        ;;
      link|apply)
        run_cli dotfiles link
        return 0
        ;;
    esac
  fi

  check_fzf
  check_tty

  local tmp_list="/tmp/dotfiles_tui_browse_$$"
  # Guard with ${:-}: this is a local, but the EXIT trap fires at process exit,
  # after the function has returned and the local is gone — unbound under set -u.
  trap 'rm -f "${tmp_list:-}"' EXIT

  build_browse_list "$tmp_list"

  if [ ! -s "$tmp_list" ]; then
    echo "No manifest entries found at $MANIFEST."
    echo "Use 'discover' to track files, or 'dotfiles add <path>'."
    return 0
  fi

  local fzf_out sel_type sel_rel
  fzf_out="$(fzf \
    --ansi \
    --header="ENTER: link all | CTRL-D: untrack entry | N: narrow dir | R: reload | Q: quit" \
    --prompt="Browse> " \
    --bind=q:abort \
    --preview="\"$DOTFILES_BIN\" audit --porcelain {2} 2>/dev/null || echo 'No audit data'" \
    --preview-window=right:50%:wrap \
    --expect=ctrl-d,ctrl-n,n,ctrl-r,r,enter \
    < "$tmp_list" || true)"

  [ -n "$fzf_out" ] || return 0

  local key line
  key="$(printf '%s\n' "$fzf_out" | head -1)"
  line="$(printf '%s\n' "$fzf_out" | sed -n '2p')"

  [ -n "$line" ] || return 0

  sel_type="$(printf '%s' "$line" | awk '{print $1}')"
  sel_rel="$(printf '%s' "$line" | awk '{print $2}')"

  case "$key" in
    ctrl-d)
      if confirm "Untrack and restore real file for $sel_rel?"; then
        case "$sel_rel" in
          "~/"*|/*) run_cli dotfiles rm "$sel_rel" ;;
          *)        run_cli dotfiles rm "~/$sel_rel" ;;
        esac
      fi
      ;;
    ctrl-n|n)
      if [ "$sel_type" = "dir" ]; then
        screen_narrow "$sel_rel"
      else
        echo "Entry $sel_rel is a file, not a dir."
      fi
      ;;
    ctrl-r|r)
      screen_browse
      ;;
    enter|"")
      run_cli dotfiles link
      ;;
  esac
}

build_browse_list() {
  local out_file="$1"
  : > "$out_file"
  [ -f "$MANIFEST" ] || return 0

  local type rel label status mark
  while IFS='|' read -r type rel label; do
    [ -n "$rel" ] || continue
    if is_linked "$rel"; then
      status="linked"
      mark="[x]"
    elif [ -e "$DOTFILES_DIR/$rel" ]; then
      status="unlinked"
      mark="[ ]"
    else
      status="absent"
      mark="[?]"
    fi
    printf '%-5s %-30s %-8s %-10s %s\n' "$type" "$rel" "$mark" "$status" "${label:-$rel}" >> "$out_file"
  done <<EOF
$(manifest_lines)
EOF
}

screen_discover() {
  if [ $# -gt 0 ]; then
    local p
    for p in "$@"; do
      case "$p" in
        "~/"*|/*) run_cli dotfiles add "$p" ;;
        *)        run_cli dotfiles add "~/$p" ;;
      esac
    done
    return 0
  fi

  check_fzf
  check_tty

  local tmp_list="/tmp/dotfiles_tui_disc_$$"
  trap 'rm -f "${tmp_list:-}"' EXIT

  if [ -n "$SCAN_BIN" ]; then
    run_cli dotfiles-scan candidates > "$tmp_list" 2>/dev/null || fallback_candidates > "$tmp_list"
  else
    fallback_candidates > "$tmp_list"
  fi

  if [ ! -s "$tmp_list" ]; then
    echo "No un-tracked candidates discovered in \$HOME."
    return 0
  fi

  local formatted_file="/tmp/dotfiles_tui_disc_fmt_$$"
  trap 'rm -f "${tmp_list:-}" "${formatted_file:-}"' EXIT

  local kind rel flags label
  : > "$formatted_file"
  while IFS='|' read -r kind rel flags label; do
    [ -n "$rel" ] || continue
    printf '%-5s %-35s [%-10s] %s\n' "$kind" "$rel" "$flags" "$label" >> "$formatted_file"
  done < "$tmp_list"

  local selections
  selections="$(fzf \
    --ansi --multi \
    --header="TAB: select multiple | ENTER: add candidate(s) | Q: quit" \
    --prompt="Discover> " \
    --bind=q:abort \
    --preview="\"$DOTFILES_BIN\" audit \"~/{2}\" 2>/dev/null || echo 'No audit info'" \
    --preview-window=right:50%:wrap \
    < "$formatted_file" || true)"

  [ -n "$selections" ] || return 0

  local sel_path sel_paths=""
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    sel_path="$(printf '%s' "$line" | awk '{print $2}')"
    [ -n "$sel_path" ] || continue
    sel_paths="$sel_paths $sel_path"
  done <<EOF
$selections
EOF

  [ -n "$sel_paths" ] || return 0

  if confirm "Add candidate(s):$sel_paths ?"; then
    for sel_path in $sel_paths; do
      case "$sel_path" in
        "~/"*|/*) run_cli dotfiles add "$sel_path" ;;
        *)        run_cli dotfiles add "~/$sel_path" ;;
      esac
    done
  fi
}

screen_narrow() {
  local target_dir="${1:-}"
  shift || true

  if [ -n "$target_dir" ] && [ $# -gt 0 ]; then
    case "$target_dir" in
      "~/"*|/*) run_cli dotfiles rm "$target_dir" ;;
      *)        run_cli dotfiles rm "~/$target_dir" ;;
    esac
    local f target_path
    for f in "$@"; do
      case "$f" in
        "~/"*|/*) target_path="$f" ;;
        "$target_dir"/*) target_path="~/$f" ;;
        *) target_path="~/$target_dir/$f" ;;
      esac
      run_cli dotfiles add "$target_path"
    done
    return 0
  fi

  check_fzf
  check_tty

  if [ -z "$target_dir" ]; then
    local dir_entries
    dir_entries="$(awk -F'|' '$1=="dir" {print $2}' "$MANIFEST" 2>/dev/null || true)"
    if [ -z "$dir_entries" ]; then
      echo "No directory (dir|) entries in manifest to narrow."
      return 0
    fi

    target_dir="$(printf '%s\n' "$dir_entries" | fzf \
      --prompt="Select dir entry to narrow> " \
      --header="Select a dir| entry to expand into individual file| entries" \
      || true)"
    [ -n "$target_dir" ] || return 0
  fi

  local tmp_expand="/tmp/dotfiles_tui_exp_$$"
  trap 'rm -f "${tmp_expand:-}"' EXIT

  if [ -n "$SCAN_BIN" ]; then
    run_cli dotfiles-scan expand "$target_dir" > "$tmp_expand" 2>/dev/null || fallback_expand "$target_dir" > "$tmp_expand"
  else
    fallback_expand "$target_dir" > "$tmp_expand"
  fi

  if [ ! -s "$tmp_expand" ]; then
    echo "No files found under ~/$target_dir."
    return 0
  fi

  local formatted_file="/tmp/dotfiles_tui_exp_fmt_$$"
  trap 'rm -f "${tmp_expand:-}" "${formatted_file:-}"' EXIT

  local kind rel flags bytes
  : > "$formatted_file"
  while IFS='|' read -r kind rel flags bytes; do
    [ -n "$rel" ] || continue
    printf '%-40s [%-10s] %s bytes\n' "$rel" "$flags" "$bytes" >> "$formatted_file"
  done < "$tmp_expand"

  local selections
  selections="$(fzf \
    --ansi --multi \
    --header="TAB: multi-select config files | ENTER: replace dir entry with selected files | Q: quit" \
    --prompt="Narrow ($target_dir)> " \
    --bind=q:abort \
    --preview="\"$DOTFILES_BIN\" audit {1} 2>/dev/null || head -n 30 ~/{1}" \
    --preview-window=right:50%:wrap \
    < "$formatted_file" || true)"

  [ -n "$selections" ] || return 0

  local sel_f sel_files=""
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    sel_f="$(printf '%s' "$line" | awk '{print $1}')"
    [ -n "$sel_f" ] || continue
    sel_files="$sel_files $sel_f"
  done <<EOF
$selections
EOF

  [ -n "$sel_files" ] || return 0

  echo "Narrowing directory $target_dir will perform:"
  echo "  1. dotfiles rm $target_dir"
  for sel_f in $sel_files; do
    echo "  2. dotfiles add ~/$sel_f"
  done

  if confirm "Execute narrowing now?"; then
    case "$target_dir" in
      "~/"*|/*) run_cli dotfiles rm "$target_dir" ;;
      *)        run_cli dotfiles rm "~/$target_dir" ;;
    esac
    for sel_f in $sel_files; do
      case "$sel_f" in
        "~/"*|/*) target_path="$sel_f" ;;
        "$target_dir"/*) target_path="~/$sel_f" ;;
        *) target_path="~/$target_dir/$sel_f" ;;
      esac
      run_cli dotfiles add "$target_path"
    done
  fi
}

screen_status() {
  local action="${1:-}"
  shift || true

  if [ -n "$action" ]; then
    case "$action" in
      sync)
        local msg="${1:-}"
        if [ -n "$msg" ]; then
          run_cli dotfiles sync -m "$msg"
        else
          run_cli dotfiles sync
        fi
        return 0
        ;;
      link|apply)
        run_cli dotfiles link
        return 0
        ;;
      audit)
        run_cli dotfiles audit
        return 0
        ;;
    esac
  fi

  check_fzf
  check_tty

  local fzf_out
  fzf_out="$(fzf \
    --ansi \
    --header="S: sync | L: link | A: audit | R: refresh | Q: quit" \
    --prompt="Dashboard> " \
    --bind=q:abort \
    --preview="\"$DOTFILES_BIN\" status" \
    --preview-window=right:80%:wrap \
    --expect=s,l,a,r,ctrl-r,enter \
    <<< "Dotfiles Dashboard — press S to sync, L to link, A to audit" || true)"

  [ -n "$fzf_out" ] || return 0

  local key
  key="$(printf '%s\n' "$fzf_out" | head -1)"

  case "$key" in
    s|S)
      printf "Commit message for sync (leave blank for default sync): " > /dev/tty
      local sync_msg=""
      read -r sync_msg < /dev/tty || sync_msg=""
      if [ -n "$sync_msg" ]; then
        run_cli dotfiles sync -m "$sync_msg"
      else
        run_cli dotfiles sync
      fi
      ;;
    l|L)
      run_cli dotfiles link
      ;;
    a|A)
      run_cli dotfiles audit
      ;;
    r|R|ctrl-r)
      screen_status
      ;;
  esac
}

show_menu() {
  check_fzf
  check_tty

  local choices="1. Browse tracked files (browse)
2. Discover candidates in \$HOME (discover)
3. Narrow a directory entry (narrow)
4. Sync / status dashboard (status)"

  local sel
  sel="$(printf '%s\n' "$choices" | fzf \
    --header="dotfiles TUI — Select a screen" \
    --prompt="Menu> " || true)"

  case "$sel" in
    1*|*browse*)   screen_browse ;;
    2*|*discover*) screen_discover ;;
    3*|*narrow*)   screen_narrow ;;
    4*|*status*)   screen_status ;;
  esac
}

usage() {
  cat <<EOF
dotfiles-tui ${VERSION} — interactive terminal UI for dotter dotfiles manager

USAGE
  dotfiles-tui [<screen>] [options]

SCREENS
  browse [rm|link <path>]    Browse tracked files, view audit info, link or untrack
  discover [path...]         Scan \$HOME for candidate configs and add them
  narrow [<dir>] [file...]   Narrow a whole-directory entry to individual files
  status [sync|link|audit]   View status dashboard and trigger sync/link/audit
  help | version

ENVIRONMENT
  DOTFILES_DIR            Repo location (default: \$HOME/.dotfiles)
  DOTFILES_TUI_DRY_RUN=1  Print CLI commands that would execute (WOULD-RUN: ...)
EOF
}

main() {
  resolve_backends

  if [ $# -eq 0 ]; then
    if [ "${DOTFILES_TUI_DRY_RUN:-0}" = "1" ]; then
      echo "WOULD-RUN: dotfiles-tui menu"
      return 0
    fi
    show_menu
    return 0
  fi

  local cmd="$1"; shift
  case "$cmd" in
    browse)            screen_browse "$@" ;;
    discover)          screen_discover "$@" ;;
    narrow)            screen_narrow "$@" ;;
    status)            screen_status "$@" ;;
    menu)              show_menu ;;
    help|--help|-h)    usage ;;
    version|--version) echo "dotfiles-tui $VERSION" ;;
    *)
      echo "error: unknown screen or command '$cmd'" >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
